      <div class="item">
        {% capture current %}{% cycle 1, 2 %}{% endcapture %}
        {{ 'lifestyle-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
        <div class="content_slideshow">
          <div class="container">
            <div class="g-content-slider {{ align_style }} {{ text_align_class }}" style="max-width: 1050px;">
              {% if block.settings.title != blank %}
              	<h4 style="font-size: {{ block.settings.title_font_size }}px; font-weight: 600; color: {{ block.settings.title_color }}; margin: 0; line-height: 1.2; letter-spacing: 2px;">{{ block.settings.title }}</h4>
              {% endif %}
              {% if block.settings.heading != blank %}
              	<h2 class="{{ heading_font_family_class }}" style="font-size: {{ block.settings.heading_font_size }}px; font-weight: 300; color: {{ block.settings.heading_color }}; text-transform: none; margin: 10px 0 35px 0; line-height: 1; letter-spacing: 3px;">{{ block.settings.heading }}</h2>
              {% endif %}
              {% if block.settings.button_name != blank %}
              <a href="{{ block.settings.button_link }}" class="btn-slider-2" style="color: {{ block.settings.button_color }}; background-color: {{ block.settings.button_bg_color }}; font-size: {{ block.settings.button_font_size }}px; border: 2px solid transparent; padding: 15px 45px; border-color: {{ block.settings.button_bg_color }}; display: inline-block;">{{ block.settings.button_name }}</a>
              {% endif %}
            </div>
          </div>
        </div> 
      </div>
      {% else %}
      <div class="item" style="background: url('{{ block.settings.image | img_url: 'master' }}') center center no-repeat;background-size: cover; min-height: {{ section.settings.height_slider }}px">
        <div class="content_slideshow">
          <div class="container">
            <div class="g-content-slider {{ align_style }} {{ text_align_class }}" style="max-width: 1050px;">
              {% if block.settings.title != blank %}
              	<h4 style="font-size: {{ block.settings.title_font_size }}px; font-weight: 600; color: {{ block.settings.title_color }}; margin: 0; line-height: 1.2; letter-spacing: 2px;">{{ block.settings.title }}</h4>
              {% endif %}
