        {% capture current %}{% cycle 1, 2 %}{% endcapture %}
        {{ 'lifestyle-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
        <div class="content_slideshow">
          <div class="container">
            <div class="g-content-slider {{ align_style }} {{ text_align_class }}" style="max-width: 530px;">
              {% if block.settings.title != blank %}
              	<h4 style="font-size: {{ block.settings.title_font_size }}px; font-weight: 700; color: {{ block.settings.title_color }}; margin: 0; line-height: 1.8; letter-spacing: 1px;">{{ block.settings.title }}</h4>
              {% endif %}
              {% if block.settings.heading != blank %}
              	<h2 class="{{ heading_font_family_class }}" style="font-size: {{ block.settings.heading_font_size }}px; font-weight: 400; color: {{ block.settings.heading_color }}; text-transform: none; margin: 0 0 15px 0; line-height: 1.2;">{{ block.settings.heading }}</h2>
              {% endif %}
              {% if block.settings.subheading != blank %}
              <p class="subheading-slider" style="font-size: {{ block.settings.subheading_font_size }}px; color: {{ block.settings.subheading_color }}; margin-bottom: 25px;">{{ block.settings.subheading }}</p>
              {% endif %}
              {% if block.settings.button_name != blank %}
              <a href="{{ block.settings.button_link }}" class="btn-slider-1" style="color: {{ block.settings.button_color }}; font-size: {{ block.settings.button_font_size }}px; border: 2px solid transparent; padding: 15px 45px; border-color: {{ block.settings.button_color }}; display: inline-block;">{{ block.settings.button_name }}</a>
