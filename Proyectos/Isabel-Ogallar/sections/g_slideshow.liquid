              {% endif %}
              {% if block.settings.button_name != blank %}
              <a href="{{ block.settings.button_link }}" class="btn" style="color: {{ block.settings.button_color }}; font-size: {{ block.settings.button_font_size }}px; background-color: {{ block.settings.button_bg_color }};">{{ block.settings.button_name }}</a>
              {% endif %}
            </div>
          </div>
        </div>   
      </div>
      {% endif %}
      {% endif %}

      {% if block.type == 'image7' %}
