{%- comment -%}
  New Product Carousel (Responsive & Bug-free)
{%- endcomment -%}

<style>
/* --- AG Premium Carousel (Scroll Snap Nativo) --- */
.ag-premium-section { padding: 40px 0; background: transparent; }
.ag-carousel-track {
  display: flex; overflow-x: auto; scroll-snap-type: x mandatory;
  scroll-behavior: smooth; gap: 10px; padding-bottom: 10px; 
  -webkit-overflow-scrolling: touch;
  -ms-overflow-style: none; scrollbar-width: none;
}
.ag-carousel-track::-webkit-scrollbar { display: none; }
.ag-carousel-item {
  scroll-snap-align: start; flex: 0 0 calc(25% - 10px); min-width: 0;
}
@media (max-width: 1200px) { .ag-carousel-item { flex: 0 0 calc(33.333% - 10px); } }
@media (max-width: 768px) { .ag-carousel-item { flex: 0 0 calc(50% - 10px); } }
@media (max-width: 480px) {
  .ag-carousel-item { flex: 0 0 85%; }
  .ag-carousel-track { padding-left: 10px; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const sliders = document.querySelectorAll('.ag-carousel-track');
  let isDown = false;
  let startX;
  let scrollLeft;

  sliders.forEach(slider => {
    slider.addEventListener('mousedown', (e) => {
      isDown = true;
      slider.style.cursor = 'grabbing';
      slider.style.scrollSnapType = 'none'; // Disable snap while dragging
      startX = e.pageX - slider.offsetLeft;
      scrollLeft = slider.scrollLeft;
    });
    slider.addEventListener('mouseleave', () => {
      isDown = false;
      slider.style.cursor = 'grab';
      slider.style.scrollSnapType = 'x mandatory';
    });
    slider.addEventListener('mouseup', () => {
      isDown = false;
      slider.style.cursor = 'grab';
      slider.style.scrollSnapType = 'x mandatory';
    });
    slider.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - slider.offsetLeft;
      const walk = (x - startX) * 2; // scroll speed
      slider.scrollLeft = scrollLeft - walk;
    });
    slider.style.cursor = 'grab';
  });
});
</script>



<div class="ag-premium-section" data-section-id="{{ section.id }}" style="width: 100%; {% if section.settings.margin != blank %}margin: {{ section.settings.margin }};{% endif %}">
  <div class="ag-carousel-inner" style="width: 100%; padding: 0;">
    
    {% if section.settings.title != blank or section.settings.subtitle != blank %}
    <div class="section-title text-center">
      {% if section.settings.title != blank %}
      <h2><span>{{ section.settings.title }}</span></h2>
      {% endif %}
      {% if section.settings.use_hr_small %}
      <hr class="hr-small">
      {% endif %}
      {% if section.settings.subtitle != blank %}
      <p>{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>
    {% endif %}

    {% assign collection = collections[section.settings.id_collection] %}
    {% assign desktop_slides = section.settings.sidetoshow | default: 5 %}
    
    <div class="g-slick-products" data-slick='{"infinite":true,"dots":false,"slidesToShow":6,"slidesToScroll":1,"autoplay":false,"arrows":true,"speed":600,"swipe":true,"draggable":true,"touchMove":true,"nextArrow":"<button type=\"button\" class=\"slick-next slick-arrow\"><i class=\"fa fa-angle-right\"></i></button>","prevArrow":"<button type=\"button\" class=\"slick-prev slick-arrow\"><i class=\"fa fa-angle-left\"></i></button>","responsive":[{"breakpoint":3000,"settings":{"slidesToShow":6,"slidesToScroll":1}},{"breakpoint":1600,"settings":{"slidesToShow":5,"slidesToScroll":1}},{"breakpoint":1200,"settings":{"slidesToShow":4,"slidesToScroll":1}},{"breakpoint":992,"settings":{"slidesToShow":3,"slidesToScroll":1}},{"breakpoint":768,"settings":{"slidesToShow":2.15,"slidesToScroll":1,"arrows":false}},{"breakpoint":480,"settings":{"slidesToShow":1.15,"slidesToScroll":1,"arrows":false}}]}'>
      {% if collection.empty? %}
        {% for i in (1..8) limit:section.settings.items_show %}
          {% include 'no-products' %}
        {% endfor %}
      {% else %}
        {% for product in collection.products limit:section.settings.items_show %}
          {% include 'g_product_carousel' %}
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.view_all_products != blank %}
    <div class="button-view-all-products text-center" style="margin-top: 30px;">
      <a href="{{ section.settings.link_view_all_products | default: collection.url | default: '#' }}" class="btn">{{ section.settings.view_all_products }}</a>
    </div>
    {% endif %}
  </div>
</div>

