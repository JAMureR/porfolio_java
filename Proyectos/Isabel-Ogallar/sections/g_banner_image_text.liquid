{%- case section.settings.css_animations -%}
    {% when '1' %}
      	{%- assign css_animations_class = '' -%}
    {% when '2' %}
    	{%- assign css_animations_class = 'wow fadeIn' -%}
    {% when '3' %}
    	{%- assign css_animations_class = 'wow fadeInDown' -%}
    {% when '4' %}
    	{%- assign css_animations_class = 'wow fadeInDownBig' -%}
    {% when '5' %}
    	{%- assign css_animations_class = 'wow fadeInLeft' -%}
    {% when '6' %}
    	{%- assign css_animations_class = 'wow fadeInLeftBig' -%}
    {% when '7' %}
    	{%- assign css_animations_class = 'wow fadeInRight' -%}
    {% when '8' %}
    	{%- assign css_animations_class = 'wow fadeInRightBig' -%}
    {% when '9' %}
    	{%- assign css_animations_class = 'wow fadeInUp' -%}
    {% when '10' %}
    	{%- assign css_animations_class = 'wow fadeInUpBig' -%}
{%- endcase -%}

{%- case section.settings.use_width -%}
    {% when '1' %}
      	{%- assign width_banner = 'g-fullwwidth' -%}
    {% when '2' %}
    	{%- assign width_banner = 'container-full' -%}
    {% when '3' %}
    	{%- assign width_banner = 'container' -%}
{%- endcase -%}

<div class="g-banner-image-text {{ css_animations_class }}" style="{% if section.settings.image != blank %}background-image: url({{ section.settings.image | img_url: 'master' | split:'?' | first }}),url({{ section.settings.image2 | img_url: 'master' | split:'?' | first }});{% endif %} {% if section.settings.margin != blank %}margin: {{ section.settings.margin }};{% endif %} {% if section.settings.padding != blank %}padding: {{ section.settings.padding }};{% endif %}">
  <div class="{{ width_banner }}">
    <div class="banner-top-img-text text-center">
      	{% if section.settings.title != blank %}
      	<h3 class="title">{{ section.settings.title }}</h3>
      	{% endif %}
      	{% if section.settings.subtitle != blank %}
      	<p class="subtitle">{{ section.settings.subtitle }}</p>
      	{% endif %}
    	{% if section.settings.image_logo != blank %}
      		<img data-src="{{ section.settings.image_logo | img_url: '217x' | split:'?' | first }}" alt="{{ section.settings.image_logo.alt }}" class="lazy">
      	{% endif %}
      	{% if section.settings.text != blank %}
      		<p class="text-font-other">{{ section.settings.text }}</p>
      	{% endif %}
    </div>
    <div class="row">
      {% for block in section.blocks %}
      {%- case block.settings.width -%}
      {% when '1' %}
      {% assign featured_banner_width = 'col-sm-3 col-xs-12' %}
      {% when '2' %}
      {% assign featured_banner_width = 'col-sm-4 col-xs-12' %}
      {% when '3' %}
      {% assign featured_banner_width = 'col-sm-6 col-xs-12' %}
      {% when '4' %}
      {% assign featured_banner_width = 'col-sm-12 col-xs-12' %}
      {%- endcase -%}
      {% case block.type %}
      {% when 'banner1' %}
      <div class="{{ featured_banner_width }} col-banner-hover col-svg-height-large">
        <div class="col-relative banner-type-1">
          <div class="banner--image">
            {% if block.settings.image != blank %}
            <div class="cover-background-carousel lazy" style="padding-top: 140%;" data-src="{{ block.settings.image | img_url: 'master', format: 'pjpg' | split:'?' | first }}"></div>
            {% else %}
            {% capture current %}{% cycle 1, 2, 3 %}{% endcapture %}
            {{ 'collection-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
          <div class="banner--info">
            {% if block.settings.title != blank %}
            <div class="js-el b-title1">{{ block.settings.title }}</div>
            {% endif %}
          </div>
          {% if block.settings.link != blank %}
          <a href="{{ block.settings.link }}" class="overflow-link"></a>
          {% endif %}
        </div>
      </div>	
      {% when 'banner2' %}
      <div class="{{ featured_banner_width }} col-banner-hover">
        <div class="col-relative col-banner-child banner-type-1">
          <div class="banner--image">
            {% if block.settings.image != blank %}
            <div class="cover-background-carousel lazy" style="padding-top: calc(70% - 15px); padding-top: -webkit-calc(70% - 15px);" data-src="{{ block.settings.image | img_url: 'master', format: 'pjpg' | split:'?' | first }}"></div>
            {% else %}
            {% capture current %}{% cycle 1, 2, 3 %}{% endcapture %}
            {{ 'collection-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
          <div class="banner--info">
            {% if block.settings.title != blank %}
            <div class="js-el b-title1">{{ block.settings.title }}</div>
            {% endif %}
          </div>
          {% if block.settings.link != blank %}
          <a href="{{ block.settings.link }}" class="overflow-link"></a>
          {% endif %}
        </div>
        <div class="col-relative col-banner-child banner-type-1">
          <div class="banner--image">
            {% if block.settings.image2 != blank %}
            <div class="cover-background-carousel lazy" style="padding-top: calc(70% - 15px); padding-top: -webkit-calc(70% - 15px);" data-src="{{ block.settings.image2 | img_url: 'master', format: 'pjpg' | split:'?' | first }}"></div>
            {% else %}
            {% capture current %}{% cycle 1, 2, 3 %}{% endcapture %}
            {{ 'collection-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
          <div class="banner--info">
            {% if block.settings.title2 != blank %}
            <div class="js-el b-title1">{{ block.settings.title2 }}</div>
            {% endif %}
          </div>
          {% if block.settings.link2 != blank %}
          <a href="{{ block.settings.link2 }}" class="overflow-link"></a>
          {% endif %}
        </div>
      </div>
      {%- endcase -%}
      {% endfor %}
    </div>
  </div>
</div>
