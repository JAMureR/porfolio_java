{%- case section.settings.css_animations -%}
    {% when '1' %}
      	{%- assign css_animations_class = '' -%}
    {% when '2' %}
    	{%- assign css_animations_class = 'wow fadeIn' -%}
    {% when '3' %}
    	{%- assign css_animations_class = 'wow fadeInDown' -%}
    {% when '4' %}
    	{%- assign css_animations_class = 'wow fadeInDownBig' -%}
    {% when '5' %}
    	{%- assign css_animations_class = 'wow fadeInLeft' -%}
    {% when '6' %}
    	{%- assign css_animations_class = 'wow fadeInLeftBig' -%}
    {% when '7' %}
    	{%- assign css_animations_class = 'wow fadeInRight' -%}
    {% when '8' %}
    	{%- assign css_animations_class = 'wow fadeInRightBig' -%}
    {% when '9' %}
    	{%- assign css_animations_class = 'wow fadeInUp' -%}
    {% when '10' %}
    	{%- assign css_animations_class = 'wow fadeInUpBig' -%}
{%- endcase -%}

{%- case section.settings.use_width -%}
    {% when '1' %}
      	{%- assign width_banner = 'g-fullwwidth' -%}
    {% when '2' %}
    	{%- assign width_banner = 'container-full' -%}
    {% when '3' %}
    	{%- assign width_banner = 'container' -%}
{%- endcase -%}

<div class="g-banner-fullwidth" {% if section.settings.margin != blank %}style="margin: {{ section.settings.margin }};"{% endif %}>
  <div class="{{ width_banner }}">
    <div class="row">
      {% for block in section.blocks %}
      {%- case block.settings.width -%}
      {% when '1' %}
      {% assign featured_banner_width = 'col-sm-4 col-xs-12' %}
      {% when '2' %}
      {% assign featured_banner_width = 'col-sm-6 col-xs-12' %}
      {% when '3' %}
      {% assign featured_banner_width = 'col-sm-12 col-xs-12' %}
      {%- endcase -%}
      <div class="{{ featured_banner_width }}">
        <div class="col-relative">
          <div class="banner--image-full">
            {% if block.settings.image != blank %}
            <div class="cover-background-full lazy" data-src="{{ block.settings.image | img_url: 'master', format: 'pjpg' | split:'?' | first }}"></div>
            {% else %}
            {% capture current %}{% cycle 1, 2, 3, 4 %}{% endcapture %}
            {{ 'collection-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
          <div class="banner--info {{ css_animations_class }}">
            <div class="table-banner">
              <div class="table-cell-banner text-center">
                {% if block.settings.title != blank %}
                <div class="title" style="color: {{ block.settings.title_color }};">{{ block.settings.title }}</div>
                {% endif %}
                {% if block.settings.heading != blank %}
                <div class="heading" style="font-size: {{ block.settings.heading_font_size }}px; color: {{ block.settings.heading_color }};">{{ block.settings.heading }}</div>
                {% endif %}
                {% if block.settings.button_name != blank %}
                <a href="{{ block.settings.button_link }}" class="btn btn-size-md btn-style-outline" style="{% if block.settings.button_color != blank %}color: {{ block.settings.button_color }}; border-color: {{ block.settings.button_bg_color }};{% endif %}{% if block.settings.button_bg_color != blank %}background-color: {{ block.settings.button_bg_color }};{% endif %}">{{ block.settings.button_name }}</a>  
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</div>
{% schema %}
  {
    "name": "Banner full width",
    "class": "globo_banner_full_width",
    "max_blocks": 8,
    "presets": [
      {
        "name": "Banner full width",
        "category": "Categories & Banner",
        "blocks" : [
          {
            "type": "block_banner"
          },
          {
            "type": "block_banner"
          }
        ]
      }
    ],
    "settings": [
        {
        "type": "select",
        "id": "css_animations",
        "label": "CSS Animation",
        "options": [
            { "value": "1", "label": "None" },
            { "value": "2", "label": "fadeIn" },
            { "value": "3", "label": "fadeInDown" },
            { "value": "4", "label": "fadeInDownBig" },
            { "value": "5", "label": "fadeInLeft" },
            { "value": "6", "label": "fadeInLeftBig" },
            { "value": "7", "label": "fadeInRight" },
            { "value": "8", "label": "fadeInRightBig" },
            { "value": "9", "label": "fadeInUp" },
            { "value": "10", "label": "fadeInUpBig" }
          ],
          "default": "2"
        },
        {
          "type": "select",
          "id": "use_width",
          "label": "One banner width",
          "options": [
            { "value": "1", "label": "Use full width" },
            { "value": "2", "label": "Use padding" },
            { "value": "3", "label": "Use container" }
          ],
          "default": "1"
        },
        {
          "type": "text",
          "id": "margin",
          "label": "Margin: (top-right-bottom-left)",
          "info": "Ex: 10px 0 30px 0"
        }
    ],
    "blocks": [
    {
      "type": "block_banner",
      "name": "Block Banner",
      "settings": [
        {
          "type": "select",
          "id": "width",
          "label": "Width",
          "default": "3",
          "options": [
               {
                 "value": "1",
                 "label": "33.33333%"
               },
               {
                 "value": "2",
                 "label": "50%"
               },
               {
                 "value": "3",
                 "label": "100%"
               }
             ]
         },
         {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
         },
         {
             "type": "text",
             "id": "title",
             "label": "Title",
			 "default": "GET WHAT YOU REALLY WANTED"
         },
         {
            "type": "color",
            "id": "title_color",
            "label": "Title color",
            "default": "#ffffff"
         },
         {
             "type": "text",
             "id": "heading",
             "label": "Heading",
			 "default": "New Summer"
         },
         {
            "type": "color",
            "id": "heading_color",
            "label": "Heading color",
            "default": "#ffffff"
         },
         {
            "type": "text",
            "id": "heading_font_size",
            "label": "Heading font size",
            "default": "140"
         },
         {
             "type": "text",
             "id": "button_name",
             "label": "Button name",
			 "default": "SHOP NOW"
         },
         {
            "type": "color",
            "id": "button_color",
            "label": "Button color",
            "default": "#262626"
         },
         {
            "type": "color",
            "id": "button_bg_color",
            "label": "Button background color",
            "default": "#ffffff"
         },
         {
             "type":"url",
             "id":"button_link",
             "label":"Button link",
             "info": "Optional"
         }
      ]
    }
   ]
  }
{% endschema %}