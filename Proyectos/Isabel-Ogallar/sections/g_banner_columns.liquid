            <div class="js-el b-title2 b-font-2">{{ block.settings.heading }}</div>
            {% endif %}
            {% if block.settings.text != blank %}
            <div class="js-el b-title3 light b-font-3">{{ block.settings.text }}</div>
            {% endif %}
            {% if block.settings.button_name != blank %}
            <a class="banner--btn" href="{{ block.settings.link }}" title="{{ block.settings.button_name }}" tabindex="0">{{ block.settings.button_name }}</a>
            {% endif %}
          </div>
          {% if block.settings.link != blank %}
