            {% endif %}
          </div>
          {% if block.settings.link2 != blank %}
          <a href="{{ block.settings.link2 }}" class="overflow-link"></a>
          {% endif %}
        </div>
      </div>
      {% endif %}
      {% if block.type == 'banner3' %}
      <div class="{{ featured_banner_width }} col-banner-hover margin-bottom-30">
        <div class="col-relative banner-type-7">
          <div class="banner--image">
            {% if block.settings.image != blank %}
            <img data-src="{{ block.settings.image | img_url: 'master', format: 'pjpg' | split:'?' | first }}" src="{{ 'pixel.gif' | asset_url }}" alt="{{ block.settings.image.alt }}" class="lazy">
            {% else %}
            {% capture current %}{% cycle 1, 2, 3 %}{% endcapture %}
            {{ 'collection-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
          <div class="banner--info">
            {% if block.settings.title != blank %}
			<div class="js-el b-title1">{{ block.settings.title }}</div>
            {% endif %}
            {% if block.settings.heading != blank %}
            <div class="js-el b-title2">{{ block.settings.heading }}</div>
            {% endif %}
            {% if block.settings.text != blank %}
            <div class="js-el b-title3 light">{{ block.settings.text }}</div>
            {% endif %}
            {% if block.settings.button_name != blank %}
            <a class="banner--btn" href="{{ block.settings.link }}" title="{{ block.settings.button_name }}" tabindex="0">{{ block.settings.button_name }}</a>
            {% endif %}
          </div>
          {% if block.settings.link != blank %}
          <a href="{{ block.settings.link }}" class="overflow-link"></a>
          {% endif %}
        </div>
      </div>
      {% endif %}
      {% if block.type == 'banner4' %}
