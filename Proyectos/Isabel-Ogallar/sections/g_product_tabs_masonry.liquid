{%- case section.settings.css_animations -%}
    {% when '1' %}
      	{%- assign css_animations_class = '' -%}
    {% when '2' %}
    	{%- assign css_animations_class = 'wow fadeIn' -%}
    {% when '3' %}
    	{%- assign css_animations_class = 'wow fadeInDown' -%}
    {% when '4' %}
    	{%- assign css_animations_class = 'wow fadeInDownBig' -%}
    {% when '5' %}
    	{%- assign css_animations_class = 'wow fadeInLeft' -%}
    {% when '6' %}
    	{%- assign css_animations_class = 'wow fadeInLeftBig' -%}
    {% when '7' %}
    	{%- assign css_animations_class = 'wow fadeInRight' -%}
    {% when '8' %}
    	{%- assign css_animations_class = 'wow fadeInRightBig' -%}
    {% when '9' %}
    	{%- assign css_animations_class = 'wow fadeInUp' -%}
    {% when '10' %}
    	{%- assign css_animations_class = 'wow fadeInUpBig' -%}
{%- endcase -%}

{%- case section.settings.product_per_row -%}
    {% when '3' %}
      	{%- assign slider_class_width = 'xlg-grid-3-items lg-grid-3-items md-grid-3-items' -%}
    {% when '4' %}
    	{%- assign slider_class_width = 'xlg-grid-4-items lg-grid-4-items md-grid-4-items' -%}
{%- endcase -%}

{%- case section.settings.width -%}
    {% when '1' %}
      	{%- assign width_class = 'container-full' -%}
    {% when '2' %}
    	{%- assign width_class = 'container-full-no-padding' -%}
    {% when '3' %}
    	{%- assign width_class = 'container' -%}
{%- endcase -%}

{%- case section.settings.tabs_style -%}
    {% when '1' %}
      	{%- assign tab_style_class = 'g-product-tabs-grid_style1' -%}
    {% when '2' %}
    	{%- assign tab_style_class = 'g-product-tabs-grid_style2' -%}
    {% when '3' %}
    	{%- assign tab_style_class = 'g-product-tabs-grid_style3' -%}
{%- endcase -%}

{%- case section.settings.style -%}
    {% when '1' %}
      	{%- assign style_class = 'g-product-masonry_style1' -%}
    {% when '2' %}
    	{%- assign style_class = 'g-product-masonry_style2' -%}
{%- endcase -%}

{%- case section.settings.heading_font_family -%}
{% when '1' %}
{%- assign heading_font_family_class = 'heading_font_family-1' -%}
{% when '2' %}
{%- assign heading_font_family_class = 'heading_font_family-2' -%}
{%- endcase -%}

<div class="g-product-tabs-grid g-product-tabs-masonry {{ style_class }} {{ css_animations_class }}" {% if section.settings.margin != blank %}style="margin: {{ section.settings.margin }};"{% endif %}>
  <div class="{{ width_class }}">
    <div class="{% if section.settings.title != blank %}section-header{% endif %} text-center">
      {% if section.settings.title != blank %}
      <h3 class="{{ heading_font_family_class }}" style="{% if section.settings.title_font_size != blank %}font-size: {{ section.settings.title_font_size }}px;{% endif %}{% if section.settings.title_letter_spacing != blank %}letter-spacing: {{ section.settings.title_letter_spacing }}px;{% endif %}">{{ section.settings.title }}</h3>
      {% endif %}
      {% if section.settings.use_hr_small %}
      <div class="hr-small"></div>
      {% endif %}
      {% if section.settings.subtitle != blank %}
      <p>{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>
    {% if section.blocks.size > 0 and section.blocks.size != 1 %}
    <ul class="nav nav-tabs-products {{ tab_style_class }}">
      {%- for block in section.blocks -%}
      {% assign collection = collections[block.settings.id_collection] %}
      <li class="{% if forloop.first%}active{% endif %}">
        <a href="#vc_tab_{{ block.id }}" data-toggle="tab" aria-expanded="false">
          <span>{% if block.settings.title != blank %}{{ block.settings.title }}{% endif %}</span>
        </a>
      </li>
      {%- endfor -%}
    </ul>
    {% endif %}
    <div class="tab-content">
      {%- for block in section.blocks -%}
      {% assign collection = collections[block.settings.id_collection] %}
      <div class="tab-pane{% if forloop.first%} active{% endif %}" id="vc_tab_{{ block.id }}">
        <div class="products products-grid prods_masonry la-isotope-container grid-space-20 {{ slider_class_width }} sm-grid-3-items xs-grid-2-items mb-grid-1-items" data-item_selector=".product_item" data-item_margin="0" data-item-width="570" data-item-height="355" data-portfolionumber="{{ section.settings.product_per_row }}" data-md-col="3" data-sm-col="2" data-xs-col="1" data-mb-col="1">
          {% if collection.empty? %}
          {% for i in (1..20) limit:block.settings.items_show %}
          	{% include 'no-products-masonry' %}
          {% endfor %}
          {% else %}
          {% for product in collection.products limit:block.settings.items_show %}
          {% include 'g_product_masonry' %} 
          {% endfor %}
          {% endif %}
        </div>
      </div>
      {%- endfor -%}
    </div>
    {% if section.settings.view_all_products != blank %}
    <div class="button-view-all-products text-center"><a href="{{ section.settings.link_view_all_products }}">{{ section.settings.view_all_products }}</a></div>
    {% endif %}
  </div>
</div>
{% schema %}
