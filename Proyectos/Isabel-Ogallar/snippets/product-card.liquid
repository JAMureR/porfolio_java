{%- assign g_sale = false -%}
{%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
  {%- assign g_sale = true -%}
{%- endif -%}
{%- assign g_current_variant = product.selected_or_first_available_variant -%}
{%- if template contains 'collection' and current_tags.size > 0 and product.has_only_default_variant == false -%}
   {%- assign url_gl = g_current_variant.url -%}
   {%- assign url_gl_tr = true -%}
{%- else -%}
  {%- assign url_gl_tr = false -%}
  {%- assign url_gl = product.url -%}
{%- endif -%}

{%- assign g_sold_out = true -%}
{%- if product.available  -%}
  {%- assign g_sold_out = false -%}
{%- endif -%}

{%- assign g_new = false -%}
{%- for tag in product.tags -%}
  {%- assign g_tag_handle = tag | handle -%}
  {%- if g_tag_handle == 'new' -%}
    {%- assign g_new = true -%}
  {%- endif -%}
{%- endfor -%}

{%- assign g_hot = false -%}
{%- for tag in product.tags -%}
  {%- assign g_tag_handle = tag | handle -%}
  {%- if g_tag_handle == 'hot' -%}
    {%- assign g_hot = true -%}
  {%- endif -%}
{%- endfor -%}

<product-card class="product-card" handle="{{ product.handle }}">
  <div class="product-card__figure">
    {%- if g_sale or g_sold_out or g_new or g_hot -%}
    <badge-list class="badge-list badge-list--vertical">
      {%- if g_sale -%}
        <span class="badge badge--custom badge--sale">{{ 'products.product.on_sale' | t }}</span>
      {%- elsif g_hot -%}
        <span class="badge badge--custom badge--hot">{{ 'products.product.hot' | t }}</span>
      {%- elsif g_sold_out -%}
        <span class="badge badge--custom badge--sold-out">{{ 'products.product.sold_out' | t }}</span>
      {%- elsif g_new -%}
        <span class="badge badge--custom badge--new">{{ 'products.product.new' | t }}</span>
      {%- endif -%}
    </badge-list>
    {%- endif -%}

    <a href="{{ url_gl | within: collection }}" class="product-card__media" data-instant>
      {%- if product.featured_image -%}
        <img src="{{ product.featured_image | img_url: 'master' }}" 
             alt="{{ product.title | escape }}" 
             class="product-card__image product-card__image--primary object-cover aspect-tall">
      {%- else -%}
        <img src="{{ 'No_Image_2.png' | asset_url }}" 
             alt="{{ product.title | escape }}" 
             class="product-card__image product-card__image--primary object-cover aspect-tall">
      {%- endif -%}
      
      {%- if product.images.size > 1 -%}
        {%- for image in product.images offset: 1 limit: 2 -%}
          <img src="{{ image | img_url: 'master' }}" 
               alt="{{ product.title | escape }}" 
               class="product-card__image product-card__image--secondary object-cover aspect-tall" loading="lazy">
        {%- endfor -%}
      {%- endif -%}
    </a>

    <!-- Hover Variants as requested -->
    {%- if product.variants.size > 1 -%}
    <div class="product-card__variants show-below--">
      {%- for variant in product.variants limit: 6 -%}
        <a href="{{ url_gl | within: collection }}?variant={{ variant.id }}" class="variant-option">
          {{ variant.title }}
        </a>
      {%- endfor -%}
    </div>
    {%- endif -%}

    <!-- Original theme actions -->
    <div class="product_item_thumbnail_action product_item--action">
      <div class="wrap-addto">
        <a href="{{ url_gl | within: collection }}{%- if url_gl_tr -%}&{%- else %}/?{%- endif -%}view=quick_view" data-href="{{ url_gl | within: collection }}{%- if url_gl_tr -%}&{%- else %}/?{%- endif -%}view=quick_view" class="globo-quick-view-button quickview button la-quickview-button" title="{{ 'products.product.quick_view' | t }}" tabindex="0"><span>{{ 'products.product.quick_view' | t }}</span></a>
        {% if settings.show_wishlist %}
        {% include 'globo.wishlist.button' %}
        {% endif %}
        {% if settings.show_compare %}
        {% include 'globo.compare.button' %}
        {% endif %}
      </div>
    </div>

  </div>

  <div class="product-card__info empty:hidden">
    <div class="v-stack product-card__title-row justify-items-start gap-2">
      <div class="v-stack product-card__title justify-items-start gap-1">
        <a href="{{ url_gl | within: collection }}" class="product-title" data-instant>{{ product.title }}</a>
        <price-list class="price-list">
          <sale-price class="text-subdued">
            {%- if linklists[product.handle].links.size > 0 -%}
              {{ product.price | money }}{%- if product.compare_at_price != blank -%}–{{ product.compare_at_price | money }}{%- endif -%}
            {%- else -%}
              {%- if product.price_varies -%}
                {{ product.price_min | money }}–{{ product.price_max | money }}
              {%- elsif g_sale -%}
                <del><span class="amount">{{ product.compare_at_price  | money }}</span></del>  <ins><span class="amount">{{ product.price | money }}</span></ins>
              {%- else -%}
                {{ product.price | money }}
              {%- endif -%}
            {%- endif -%}
          </sale-price>
        </price-list>
      </div>
    </div>
  </div>
</product-card>
