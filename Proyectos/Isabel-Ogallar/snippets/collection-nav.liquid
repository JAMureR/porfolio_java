{%- if template.suffix != blank -%}
{%- assign g_check_template = true -%} 
{%- else -%}
{%- assign g_check_template = false -%} 
{%- endif -%}

{%- assign g_secure_url = '/collections' -%}
{%- if canonical_url contains '?page' -%}
{%- assign _g_canonical_url_remove = canonical_url | split:g_secure_url | last -%}
{%- assign g_canonical_url_remove = _g_canonical_url_remove | split:'?page' | first -%}
{%- else -%}
{%- assign g_canonical_url_remove = canonical_url | split:g_secure_url | last -%}
{%- endif -%}
{%- case settings.layout -%}
{% when 'grid' %}
  <div class="wc-toolbar-container {% if settings.use_no_gutter %}container{% endif %}">
    <div class="wc-toolbar wc-toolbar-top clearfix">
      <div class="wc-toolbar-left">
        <p class="woocommerce-result-count">
          {{ 'collections.general.showing' | t }} 1&ndash;{{ limit }} {{ 'collections.general.of' | t }} {{ collection.products_count }} {{ 'collections.general.results' | t }}
        </p>
      </div>
      <div class="wc-toolbar-right">
        <div class="wc-view-toggle">
          <span data-view_mode="grid" class="active"><i title="Vista Grid" class="fa fa-th"></i></span>
          <span data-view_mode="list"><i title="Vista Lista" class="fa fa-list"></i></span>
        </div>
        <div class="btn-advanced-shop-filter">
          <span>{{ 'collections.general.filter' | t }}</span><i></i>
        </div>
        {% if settings.sort_enable %}
        {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
        <div class="wc-ordering">
          <p>{{ 'collections.general.sort_by' | t }}</p>
          <ul>
            {% if sort_by == collection.default_sort_by %}
            {% if collection.default_sort_by != 'manual' %}
            <li class="{% if sort_by == "manual" %}active{% endif %}"><a href="/collections{{g_canonical_url_remove}}?sort_by=manual{%- if g_check_template -%}&view={{template.suffix}}{%- endif -%}">{{ 'collections.sorting.featured' | t }}</a></li>
            {% endif %}
            {% if collection.default_sort_by != 'best-selling' %}
            <li class="{% if sort_by == "best-selling" %}active{% endif %}"><a href="/collections{{g_canonical_url_remove}}?sort_by=best-selling{%- if g_check_template -%}&view={{template.suffix}}{%- endif -%}">{{ 'collections.sorting.best_selling' | t }}</a></li>
            {% endif %}
            {% if collection.default_sort_by != 'title-ascending' %}
            <li class="{% if sort_by == "title-ascending" %}active{% endif %}"><a href="/collections{{g_canonical_url_remove}}?sort_by=title-ascending{%- if g_check_template -%}&view={{template.suffix}}{%- endif -%}">{{ 'collections.sorting.az' | t }}</a></li>
            {% endif %}
            {% if collection.default_sort_by != 'title-descending' %}
            <li class="{% if sort_by == "title-descending" %}active{% endif %}"><a href="/collections{{g_canonical_url_remove}}?sort_by=title-descending{%- if g_check_template -%}&view={{template.suffix}}{%- endif -%}">{{ 'collections.sorting.za' | t }}</a></li>
            {% endif %}
            {% if collection.default_sort_by != 'price-ascending' %}
            <li class="{% if sort_by == "price-ascending" %}active{% endif %}"><a href="/collections{{g_canonical_url_remove}}?sort_by=price-ascending{%- if g_check_template -%}&view={{template.suffix}}{%- endif -%}">{{ 'collections.sorting.price_ascending' | t }}</a></li>
            {% endif %}
            {% if collection.default_sort_by != 'price-descending' %}
            <li class="{% if sort_by == "price-descending" %}active{% endif %}"><a href="/collections{{g_canonical_url_remove}}?sort_by=price-descending{%- if g_check_template -%}&view={{template.suffix}}{%- endif -%}">{{ 'collections.sorting.price_descending' | t }}</a></li>
            {% endif %}
            {% if collection.default_sort_by != 'created-descending' %}
            <li class="{% if sort_by == "created-descending" %}active{% endif %}"><a href="/collections{{g_canonical_url_remove}}?sort_by=created-descending{%- if g_check_template -%}&view={{template.suffix}}{%- endif -%}">{{ 'collections.sorting.date_descending' | t }}</a></li>
            {% endif %}
            {% if collection.default_sort_by != 'created-ascending' %}
            <li class="{% if sort_by == "created-ascending" %}active{% endif %}"><a href="/collections{{g_canonical_url_remove}}?sort_by=created-ascending{%- if g_check_template -%}&view={{template.suffix}}{%- endif -%}">{{ 'collections.sorting.date_ascending' | t }}</a></li>
            {% endif %}
            {% else %}
            <li class="{% if sort_by == "manual" %}active{% endif %}"><a href="/collections{{g_canonical_url_remove}}?sort_by=manual{%- if g_check_template -%}&view={{template.suffix}}{%- endif -%}">{{ 'collections.sorting.featured' | t }}</a></li>
            <li class="{% if sort_by == "best-selling" %}active{% endif %}"><a href="/collections{{g_canonical_url_remove}}?sort_by=best-selling{%- if g_check_template -%}&view={{template.suffix}}{%- endif -%}">{{ 'collections.sorting.best_selling' | t }}</a></li>
            <li class="{% if sort_by == "title-ascending" %}active{% endif %}"><a href="/collections{{g_canonical_url_remove}}?sort_by=title-ascending{%- if g_check_template -%}&view={{template.suffix}}{%- endif -%}">{{ 'collections.sorting.az' | t }}</a></li>
            <li class="{% if sort_by == "title-descending" %}active{% endif %}"><a href="/collections{{g_canonical_url_remove}}?sort_by=title-descending{%- if g_check_template -%}&view={{template.suffix}}{%- endif -%}">{{ 'collections.sorting.za' | t }}</a></li>
            <li class="{% if sort_by == "price-ascending" %}active{% endif %}"><a href="/collections{{g_canonical_url_remove}}?sort_by=price-ascending{%- if g_check_template -%}&view={{template.suffix}}{%- endif -%}">{{ 'collections.sorting.price_ascending' | t }}</a></li>
            <li class="{% if sort_by == "price-descending" %}active{% endif %}"><a href="/collections{{g_canonical_url_remove}}?sort_by=price-descending{%- if g_check_template -%}&view={{template.suffix}}{%- endif -%}">{{ 'collections.sorting.price_descending' | t }}</a></li>
            <li class="{% if sort_by == "created-descending" %}active{% endif %}"><a href="/collections{{g_canonical_url_remove}}?sort_by=created-descending{%- if g_check_template -%}&view={{template.suffix}}{%- endif -%}">{{ 'collections.sorting.date_descending' | t }}</a></li>
            <li class="{% if sort_by == "created-ascending" %}active{% endif %}"><a href="/collections{{g_canonical_url_remove}}?sort_by=created-ascending{%- if g_check_template -%}&view={{template.suffix}}{%- endif -%}">{{ 'collections.sorting.date_ascending' | t }}</a></li>
            {% endif %}
          </ul>
        </div>
        {% endif %}
      </div>
    </div>
    <div class="clearfix"></div>
    <div class="la-advanced-product-filters clearfix">
      <div class="sidebar-inner clearfix">
        {% section 'filter' %}
      </div>
    </div>
  </div>
